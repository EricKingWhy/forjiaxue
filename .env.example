# ForJiaXue environment template (T155)
# Copy to .env and replace placeholder values before `docker compose up --build`.
# NEVER commit a real .env with secrets — this file is placeholders only.

# === Backend ===
# Admin password for /api/admin/auth (use a strong password in production)
ADMIN_PASSWORD=change_me_to_a_strong_password

# JWT signing secret (use a long, random string — e.g. `openssl rand -hex 32`)
JWT_SECRET=replace_with_a_long_random_secret_string

# Database URL (SQLite, relative to backend/data/)
DATABASE_URL=sqlite:///./data/app.db

# === Frontend ===
# Backend API origin the browser calls. In Docker, point at the backend host/port.
# This is baked into the frontend build (NEXT_PUBLIC_) AND available at runtime.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
